@@ -0,0 +1,116 @@
+/**
+ * FXL Sales outbound conversion webhook (cross-repo integration).
+ *
+ * Fired (fire-and-forget) after an org is marked first-paid. Posts the conversion
+ * to FXL Sales' POST /api/v1/conversions with an HMAC-signed X-FXL-Signature
+ * header. The HMAC is implemented INLINE here (this repo cannot import FXL Sales'
+ * packages/shared-utils across repos).
+ *
+ * MUST byte-match FXL Sales packages/shared-utils/src/hmac.ts verifyHmac():
+ *   payload = `${t}.${rawBody}`; hmac = HMAC-SHA256(secret, payload) hex.
+ *   header  = `t=${t},v1=${hmac}`.
+ * INVARIANT (FXL Sales D-O): sign over the IDENTICAL raw byte string sent as the
+ * request body — never re-serialize between sign → send.
+ */
+import { createHmac, createHash } from 'node:crypto'
+
+// MUST byte-match FXL Sales packages/shared-utils/src/hmac.ts verifyHmac()
+// Formula: hmac = createHmac('sha256', secret).update(t + "." + rawBody).digest('hex')
+function signPayload(rawBody: string, secret: string): string {
+  const t = Math.floor(Date.now() / 1000).toString()
+  const hmac = createHmac('sha256', secret).update(`${t}.${rawBody}`).digest('hex')
+  return `t=${t},v1=${hmac}`
+}
+
+async function sendWithRetry(url: string, body: object, secret: string): Promise<void> {
+  // Serialize ONCE — both the signature and the request body use this exact string.
+  const rawBody = JSON.stringify(body)
+  const signature = signPayload(rawBody, secret)
+  const delays = [1000, 2000, 4000] // exponential backoff (D8)
+  for (let attempt = 0; attempt <= delays.length; attempt++) {
+    try {
+      const res = await fetch(url, {
+        method: 'POST',
+        headers: {
+          'Content-Type': 'application/json',
+          'X-FXL-Signature': signature,
+        },
+        body: rawBody,
+      })
+      // Success or any non-5xx (4xx is a client error — do NOT retry).
+      if (res.ok || res.status < 500) return
+    } catch {
+      // Network error — fall through to backoff/retry.
+    }
+    if (attempt < delays.length) {
+      await new Promise((r) => setTimeout(r, delays[attempt]))
+    }
+  }
+  // Final failure: log for ops visibility. Do NOT throw — the sale flow must not be
+  // blocked by a downstream affiliate webhook. (A webhook_send_failures table is a
+  // v1.1 enhancement; ops reads logs for now.)
+  console.error('[fxl-sales-webhook] final delivery failure', { url })
+}
+
+export interface NotifyFxlFindersConversionParams {
+  orgId: string
+  clickId: string | null
+  finderCode: string | null
+  sellerClerkId: string | null
+  customerEmail: string
+  customerName: string
+  customerPhone: string | null
+  customerCpf: string | null
+  setupAmountBrl: number
+  monthlyAmountBrl: number
+  firstPaidAt: Date
+}
+
+/**
+ * Notifies FXL Sales of a closed sale. No-ops (with a warning) when the integration
+ * env vars are absent — never throws. Emits EXACTLY the FXL Sales D-M field set with
+ * source='fxl-financiero' (D-A) and a plain-SHA-256 idempotency_key (D-N).
+ */
+export async function notifyFxlFindersConversion(
+  params: NotifyFxlFindersConversionParams,
+): Promise<void> {
+  const apiUrl = process.env.FXL_FINDERS_API_URL
+  const secret = process.env.FXL_FINDERS_WEBHOOK_SECRET
+  if (!apiUrl || !secret) {
+    console.warn(
+      '[fxl-sales-webhook] FXL_FINDERS_API_URL or FXL_FINDERS_WEBHOOK_SECRET not set — skipping',
+    )
+    return
+  }
+
+  const source = 'fxl-financiero' // D-A canonical slug (…ciero) — byte-identical to FXL Sales apps.slug
+  const externalOrderId = params.orgId
+  const eventType = 'sale'
+  // D-N: idempotency_key is PLAIN SHA-256 (NOT HMAC). Byte-matches FXL Sales
+  // buildIdempotencyKey(source, externalOrderId, eventType).
+  const idempotencyKey = createHash('sha256')
+    .update(source + externalOrderId + eventType)
+    .digest('hex')
+
+  await sendWithRetry(
+    `${apiUrl}/api/v1/conversions`,
+    {
+      source,
+      external_order_id: externalOrderId,
+      event_type: eventType,
+      idempotency_key: idempotencyKey,
+      click_id: params.clickId,
+      finder_code: params.finderCode,
+      seller_clerk_id: params.sellerClerkId,
+      customer_email: params.customerEmail,
+      customer_name: params.customerName,
+      customer_phone: params.customerPhone,
+      customer_cpf: params.customerCpf,
+      customer_org_id: params.orgId,
+      realized_setup_brl: params.setupAmountBrl,
+      realized_monthly_brl: params.monthlyAmountBrl,
+      closed_at: params.firstPaidAt.toISOString(),
+    },
+    secret,
+  )
+}
