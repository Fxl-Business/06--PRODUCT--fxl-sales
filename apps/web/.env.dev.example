# apps/web/.env.dev.example
#
# Local dev defaults for the Vite app. Committed because it only contains
# the shared FXL Local Sandbox publishable key + localhost API URL.

VITE_API_URL=http://localhost:3006

# Site URL (apps/site) — used for links to public pages (Phase 03)
VITE_SITE_URL=http://localhost:4006

# --- Auth: FXL Local Sandbox (shared) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_FXL_LOCAL_SANDBOX_REPLACE_ME

# --- Observability: optional ---
VITE_SENTRY_DSN=
