{
  "name": "@fxl-sales/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:integration": "VITEST_INTEGRATION=1 vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@fxl-business/hub-sdk": "^1.2.0",
    "@fxl-sales/shared-types": "workspace:*",
    "@fxl-sales/shared-utils": "workspace:*",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.5.0",
    "@sentry/node": "^10.51.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.4",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.5",
    "svix": "^1.95.1",
    "ulidx": "^2.4.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.21.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
