# apps/api/.env.dev.example
#
# Local dev defaults. After init-from-template (or setup-dev.sh) this is
# copied verbatim to apps/api/.env and the app reads from there.
#
# This file IS committed. Reason: the Clerk keys point at the shared
# "FXL Local Sandbox" Clerk application (free, no real users). Replace the
# REPLACE_ME placeholders ONCE per template repo with the actual sandbox
# keys (see README → § First-time CTO setup).

NODE_ENV=development
PORT=3006
CORS_ORIGIN=http://localhost:8006

# Local Docker Postgres — host port matches docker-compose.yml mapping.
# Uses the project-number convention (5000 + project_number).
#
# DB roles (dev-vs-staging split — Phase 01 D-C / D-G):
#   - Runtime DATABASE_URL targets fxl_finders_app (NO BYPASSRLS, not table
#     owner) so RLS is actually ENFORCED at runtime.
#   - Migrations run as the OWNER role (fxl_finders_owner).
#   - Admin/cross-tenant ops use ADMIN_DATABASE_URL → fxl_finders_admin (BYPASSRLS).
# On a fresh local Docker DB these roles are created by the Phase 01 migration
# (the journaled migration CREATEs them with LOGIN PASSWORD). The migration
# itself must run as a superuser-capable URL (postgres) the FIRST time so it can
# CREATE ROLE / CREATE POLICY; staging/prod MUST keep these three separated.
DATABASE_URL=postgresql://fxl_finders_app:fxl_finders_app@localhost:5006/fxl_finders

# Admin / cross-tenant connection (D-C). Role fxl_finders_admin has BYPASSRLS so
# admin reads/writes span orgs. Backend-only — NEVER VITE_-prefixed.
ADMIN_DATABASE_URL=postgresql://fxl_finders_admin:fxl_finders_admin@localhost:5006/fxl_finders

# --- Auth: FXL Local Sandbox (shared across all FXL projects' local dev) ---
# NOTE (D-B, load-bearing): the Clerk session token MUST include a custom claim
#   { "publicMetadata": "{{user.public_metadata}}" }
# (Clerk dashboard → Sessions → Customize session token). Without it the backend
# reads payload.publicMetadata=undefined → userRole=undefined → every admin
# request 403s. See docs/nexo/decisions/phase01-clerk-config.md.
CLERK_SECRET_KEY=sk_test_FXL_LOCAL_SANDBOX_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_FXL_LOCAL_SANDBOX_REPLACE_ME

# --- Observability: optional in dev ---
SENTRY_DSN=

# --- Email: not needed for dev ---
RESEND_API_KEY=
RESEND_FROM=
