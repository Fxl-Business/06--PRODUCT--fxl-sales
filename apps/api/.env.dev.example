# apps/api/.env.dev.example
#
# Local dev defaults. After init-from-template (or setup-dev.sh) this is
# copied verbatim to apps/api/.env and the app reads from there.
#
# This file IS committed and contains only localhost defaults plus public Hub config.

NODE_ENV=development
PORT=3006
CORS_ORIGIN=http://localhost:8006

# Local Docker Postgres - host port matches docker-compose.yml mapping.
# Uses the project-number convention (5000 + project_number).
#
# Standard FXL single-role database URL.
# Staging/prod DBs are created by create-db.sh, which prints the value to paste here.
# Local Docker uses the postgres owner from docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5006/fxl_sales

# Optional admin DB override. Leave blank for the standard FXL single-role pattern.
ADMIN_DATABASE_URL=

# --- Auth: FXL Hub ---
FXL_HUB_API_URL=http://localhost:9016
FXL_HUB_PUBLISHABLE_KEY=pk_fxl-sales_VzQ9-LUONCnlKllxCRLffN3nw6Z9PQl2
# Secret key is shown once by the Hub admin panel. Never commit a real value.
FXL_HUB_SECRET_KEY=
# Normally unset. Any explicit override must be exactly product.fxl-sales.
FXL_HUB_AUDIENCE=
# Exact registered local callback.
FXL_HUB_REDIRECT_URI=http://localhost:8006/auth/callback
# Optional. Defaults to CORS_ORIGIN after a successful Hub callback.
FXL_HUB_POST_LOGIN_REDIRECT=
FXL_HUB_POST_LOGIN_ERROR_REDIRECT=

# Public origin used for generated referral links.
PUBLIC_LINK_BASE_URL=http://localhost:3006

# --- Observability: optional in dev ---
SENTRY_DSN=

# --- Email: not needed for dev ---
RESEND_API_KEY=
RESEND_FROM=
