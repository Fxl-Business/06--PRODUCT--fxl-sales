# --- Server ---
NODE_ENV=development
PORT=3006
CORS_ORIGIN=http://localhost:8006

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5006/fxl_finders

# --- Auth provider ---
AUTH_PROVIDER=clerk

# --- Auth (Clerk rollback path) ---
# Get keys from https://dashboard.clerk.com/
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Clerk webhook signing secret (Phase 05): Clerk Dashboard → Webhooks → POST
# /api/v1/webhooks/clerk → Signing Secret (whsec_...). Backfills sellers.clerk_user_id.
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Auth (FXL Hub) ---
FXL_HUB_API_URL=http://localhost:9016
FXL_HUB_PUBLISHABLE_KEY=pk_fxl-sales_VzQ9-LUONCnlKllxCRLffN3nw6Z9PQl2
FXL_HUB_SECRET_KEY=
FXL_HUB_AUDIENCE=
# Required in production Hub mode. Must match the Hub OAuth client redirect URI.
FXL_HUB_REDIRECT_URI=
# Optional. Defaults to CORS_ORIGIN after a successful Hub callback.
FXL_HUB_POST_LOGIN_REDIRECT=
FXL_HUB_POST_LOGIN_ERROR_REDIRECT=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Email (optional, Resend) ---
RESEND_API_KEY=
RESEND_FROM=
